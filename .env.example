NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-secret

ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminclimb

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Analytics 4 — find dit Measurement ID i GA4 under Admin > Data Streams
NEXT_PUBLIC_GA_ID=

# Google Analytics Data API — viser rigtige besøgstal på /admin/statistik.
# Kræver en Google Cloud-service-konto med Viewer-adgang til GA4-ejendommen.
# GA_PROPERTY_ID = kun tallene fra property-id (fx 533945728, IKKE G-...).
# GA_SA_PRIVATE_KEY indsættes med \n bevaret (Vercel håndterer det).
# Er de tomme, viser statistik-siden bare links ud til Google Analytics.
GA_PROPERTY_ID=
GA_SA_CLIENT_EMAIL=
GA_SA_PRIVATE_KEY=

# Webshop — Stripe hemmelig nøgle (sk_live_... eller sk_test_...).
# Findes i Stripe Dashboard > Developers > API keys. SKAL sættes for at
# checkout virker. Uden den vises en venlig fejl ved betaling.
STRIPE_SECRET_KEY=

# SEO — det primære (canonical) domæne. SKAL sættes i Vercel ellers bruges
# vercel.app-domænet i canonical, sitemap og struktureret data.
NEXT_PUBLIC_SITE_URL=https://www.traeklatreskolen.dk

# Kontakt + sociale profiler — vises i struktureret data (Google/AI).
# Lad stå tomme indtil de findes; tomme felter udelades automatisk.
NEXT_PUBLIC_PHONE=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_YOUTUBE_URL=
NEXT_PUBLIC_LINKEDIN_URL=
